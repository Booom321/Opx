{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/Output/Build/${presetName}",
      "installDir": "${sourceDir}/Output/Install/${presetName}",
      "cacheVariables": {
        "CMAKE_DEBUG_POSTFIX": "",
        "CMAKE_RELEASE_POSTFIX": "",
        "CMAKE_RELWITHDEBINFO_POSTFIX": "",
        "CMAKE_MINSIZEREL_POSTFIX": "",
        "BUILD_SHARED_LIBS": "OFF",

        "PROJECT_NAME": "Opx",
        "MACRO_PREFIX": "OPX",
        "NAMESPACE_NAME": "Opx",
        "CXX_STANDARD": "17",
        "C_STANDARD": "11"
      }
    },
    {
      "name": "debug-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "windows-base",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Debug-x64",
      "inherits": ["windows-base", "debug-base"],
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "Release-x64",
      "inherits": ["windows-base", "release-base"],
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "Debug-x86",
      "inherits": ["windows-base", "debug-base"],
      "architecture": {
        "value": "x86",
        "strategy": "external"
      }
    },
    {
      "name": "Release-x86",
      "inherits": ["windows-base", "release-base"],
      "architecture": {
        "value": "x86",
        "strategy": "external"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-x64-debug",
      "configurePreset": "Debug-x64"
    },
    {
      "name": "build-windows-x64-release",
      "configurePreset": "Release-x64"
    },
    {
      "name": "build-windows-x86-debug",
      "configurePreset": "Debug-x86"
    },
    {
      "name": "build-windows-x86-release",
      "configurePreset": "Release-x86"
    }
  ]
}
